{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug server.ts (ts-node)",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--loader",
        "ts-node/esm"
      ],
      "args": ["${workspaceFolder}/src/server.ts"],
      "sourceMaps": true,
      "cwd": "${workspaceFolder}"
    }
  ]
}